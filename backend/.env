# Protocol Selection
PROTOCOL_TYPE=onvif
LOCAL_STORAGE_PATH=D:\CCTV_Recordings

# FTP Settings (used when PROTOCOL_TYPE=ftp)
FTP_HOST=192.168.1.100
FTP_PORT=21
FTP_USER=admin
FTP_PASSWORD=your_password
FTP_PATH=/Recordings

# ONVIF Settings (used when PROTOCOL_TYPE=onvif)
ONVIF_ENABLED=true
ONVIF_HOST=192.168.1.100
ONVIF_PORT=80
ONVIF_USER=admin
ONVIF_PASSWORD=your_password
ONVIF_DAYS_BACK=3

# Google Drive Settings
STORAGE_DESTINATION=both
DRIVE_BACKUP_FOLDER=CCTV_Backup
# OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=112852850182-q3ehc9tdt5ogpkdebersau5mdusfpval.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=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
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/drive/oauth2callback

# Application Settings
SYNC_INTERVAL_MINUTES=60
DELETE_AFTER_UPLOAD=false
MAX_FILE_AGE_DAYS=30
DB_PATH=cctv_backup.db

# Flask Settings
